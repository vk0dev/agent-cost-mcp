{"version":3,"term":{"cols":80,"rows":24},"timestamp":1777203285,"command":"node scripts/demo-anomaly.mjs","env":{"SHELL":"/bin/zsh"}}
[0.469, "o", "\u001b[2m# Story: an agent ran a Read-loop overnight.\u001b[0m\r\n"]
[0.001, "o", "\u001b[2m# 14 turns. Did anyone notice?\u001b[0m\r\n"]
[2.201, "o", "\r\n\u001b[1m$ npx -y @vk0/agent-cost-mcp@^2 ./session.jsonl\u001b[0m\r\n"]
[0.901, "o", "\u001b[2m  parsing session log...\u001b[0m\r\n"]
[0.801, "o", "\r\n"]
[0.000, "o", "\u001b[36m\u001b[1m>>> get_session_cost(session)\u001b[0m\r\n"]
[0.705, "o", "  turns: \u001b[1m9\u001b[0m\r\n"]
[0.001, "o", "  total cost: \u001b[31m\u001b[1m$8.66\u001b[0m  \u001b[2m(in one session)\u001b[0m\r\n"]
[0.033, "o", "  cache reads: \u001b[33m843,170 tokens\u001b[0m  \u001b[2m‚Äî that's where the burn went\u001b[0m\r\n"]
[2.000, "o", "\r\n"]
[0.000, "o", "\u001b[36m\u001b[1m>>> get_tool_roi(session)\u001b[0m\r\n"]
[0.707, "o", "  2 tools used. Per-tool ROI:\r\n"]
[0.701, "o", "  \u001b[31m‚óè Edit  \u001b[0m  calls=\u001b[1m 4\u001b[0m  cost=$ 3.85  linked= 0  \u001b[31mlow   \u001b[0m\r\n"]
[0.000, "o", "  \u001b[32m‚óè Read  \u001b[0m  calls=\u001b[1m 5\u001b[0m  cost=$ 4.81  linked= 9  \u001b[32mhigh  \u001b[0m\r\n"]
[2.000, "o", "\r\n"]
[0.000, "o", "\u001b[31m\u001b[1m  ‚öÝ Edit: 4 calls, 0 linked results ‚Äî agent fired tools, ignored output.\u001b[0m\r\n"]
[0.000, "o", "\u001b[31m\u001b[1m  ‚öÝ That's a runaway-loop signature. Cost Guard catches it locally,\u001b[0m\r\n\u001b[31m\u001b[1m    no dashboard, no telemetry, no API key.\u001b[0m\r\n"]
[2.405, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[32m‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ\u001b[0m\r\n\u001b[1mccusage tells you what you spent.\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[32magent-cost-mcp\u001b[0m\u001b[1m stops you from spending it.\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[32m‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ\u001b[0m\r\n"]
[1.800, "o", "\r\n"]
[0.000, "o", "\u001b[2mnpm install -g @vk0/agent-cost-mcp ¬∑ v2.0.0-beta.4\u001b[0m\r\n"]
