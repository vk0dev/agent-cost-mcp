{"version":3,"term":{"cols":80,"rows":24},"timestamp":1777460199,"command":"node scripts/demo-subagent-tree.mjs","env":{"SHELL":"/bin/zsh"}}
[0.110, "o", "\u001b[2m# An agent dispatched a subagent overnight. Both billed.\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# Which branch burned the budget?\u001b[0m\r\n"]
[2.202, "o", "\r\n"]
[0.000, "o", "\u001b[1m$ npx -y @vk0/agent-cost-mcp@beta\u001b[0m\r\n"]
[0.701, "o", "\u001b[2m  parsing parent + subagent JSONLs...\u001b[0m\r\n"]
[0.802, "o", "\r\n"]
[0.000, "o", "\u001b[36m\u001b[1m>>> get_subagent_tree(session)\u001b[0m\r\n"]
[0.709, "o", "  \u001b[1mtotal: $8.69\u001b[0m  across 3 sessions\r\n"]
[0.000, "o", "\r\n"]
[0.902, "o", "  \u001b[1msession-subagent    \u001b[0m  \u001b[31m  $8.69\u001b[0m  \u001b[2m(100% of total)\u001b[0m\r\n"]
[0.000, "o", "  ‚îú‚îÄ‚îÄ \u001b[1mdemo-anomaly        \u001b[0m  \u001b[31m  $8.66\u001b[0m  \u001b[2m(100% of total)\u001b[0m\r\n  ‚îî‚îÄ‚îÄ \u001b[1msession-main        \u001b[0m  \u001b[32m  $0.01\u001b[0m  \u001b[2m(  0% of total)\u001b[0m\r\n"]
[2.201, "o", "\r\n\u001b[31m\u001b[1m  ‚öÝ demo-anomaly subagent ate 99% of the spend.\u001b[0m\r\n\u001b[31m\u001b[1m    Without this view, you'd see only the rollup ($8.69) and\u001b[0m\r\n\u001b[31m\u001b[1m    miss which child agent went sideways.\u001b[0m\r\n"]
[2.401, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[32m‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ\u001b[0m\r\n"]
[0.000, "o", "\u001b[1mccusage gives you a flat table.\u001b[0m\r\n\u001b[1m\u001b[32magent-cost-mcp\u001b[0m\u001b[1m gives you the tree, structured.\u001b[0m\r\n\u001b[2mMCP-native output ‚Äî your client can render this directly.\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[32m‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ\u001b[0m\r\n"]
