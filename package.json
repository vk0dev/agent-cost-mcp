{
  "name": "@vk0/agent-cost-mcp",
  "version": "2.0.0-beta.1",
  "description": "Local-first Claude Code cost analyzer. Parses JSONL session logs to surface per-tool spend, daily trends, and optimization hints. Zero cloud, no API key.",
  "mcpName": "io.github.vk0dev/agent-cost-mcp",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "agent-cost-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "smoke": "npm run build && node scripts/dogfood_smoke.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "anthropic",
    "ai-agent",
    "llm-cost",
    "token-usage",
    "cost-tracking",
    "cost-analyzer",
    "observability",
    "agent-observability",
    "opus",
    "sonnet",
    "jsonl",
    "cost-optimization",
    "developer-tools",
    "local-first"
  ],
  "author": "vk0.dev",
  "license": "MIT",
  "homepage": "https://vk0dev.github.io/agent-cost-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/vk0dev/agent-cost-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vk0dev/agent-cost-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}